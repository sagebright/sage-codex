# =============================================================================
# Sage Codex — Tier 2 E2E Integration Test Environment
# =============================================================================
#
# Copy this file to .env.e2e and fill in the values.
# These variables are used by the Tier 2 integration tests that run
# against a real API server + Supabase backend.
#
# NEVER commit .env.e2e — it contains secrets.

# ---- Supabase Connection ----
# The Supabase project URL and anonymous (public) key.
# Use a dedicated test project or the development project.
E2E_SUPABASE_URL=https://your-project.supabase.co
E2E_SUPABASE_ANON_KEY=eyJ...your-anon-key

# ---- Test User Credentials ----
# A pre-created user in the Supabase auth system.
# Create one via the Supabase dashboard or with:
#   supabase auth create-user --email test@e2e.local --password <password>
E2E_TEST_USER_EMAIL=test@e2e.local
E2E_TEST_USER_PASSWORD=secure-test-password

# ---- API Server ----
# Port the API server listens on (default: 3001).
# Only change if your dev setup uses a different port.
# API_PORT=3001
